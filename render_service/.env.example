GODDARD_REPLICATE_BASE_URL=https://api.replicate.com/v1
GODDARD_REPLICATE_HEIGHT=768
GODDARD_REPLICATE_WAIT_SECONDS=60
GODDARD_REPLICATE_TIMEOUT_SECONDS=120

# Optional secondary fallback
GODDARD_OPENAI_API_KEY=
OPENAI_API_KEY=
