GODDARD_RENDER_PROVIDER=auto
GODDARD_ANIM_STRATEGY=hero_loop
GODDARD_DEVICE_URL=http://192.168.8.141

# Primary provider: Replicate z-image-turbo
GODDARD_REPLICATE_API_TOKEN=
REPLICATE_API_TOKEN=
